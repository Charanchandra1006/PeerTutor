{
  "name": "ptm-backend",
  "version": "1.0.0",
  "description": "PTM Backend API — Node.js + Express + MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --coverage",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit --detectOpenHandles",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "seed": "node src/seed.js",
    "worker": "node src/jobs/worker.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "mongoose": "^8.7.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.12.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "zod": "^3.23.8",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "morgan": "^1.10.0",
    "winston": "^3.14.2",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "validator": "^13.12.0",
    "cloudinary": "^2.4.0",
    "@sendgrid/mail": "^8.1.3",
    "prom-client": "^15.1.3",
    "dotenv": "^16.4.5",
    "joi": "^17.13.3",
    "crypto-js": "^4.2.0",
    "multer": "^1.4.5-lts.1",
    "slugify": "^1.6.6",
    "http-status-codes": "^2.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "mongodb-memory-server": "^10.0.0",
    "eslint": "^8.57.0",
    "@faker-js/faker": "^8.4.1"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testTimeout": 30000
  }
}
